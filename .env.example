NEXT_PUBLIC_API_BASE_URL=http://localhost:4000 # Backend API origin; no trailing slash; must match LawyerAI-api and backend FRONTEND_URL/CORS.

NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key # Required for Google sign-in together with AUTH_DOMAIN and PROJECT_ID.
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com # Firebase Authentication domain.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id # Firebase project id.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com # Optional; include if you use Firebase Storage from the web config.
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000 # Optional messaging sender id.
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:000000000000000000000 # Optional Firebase app id.

JWT_ACCESS_SECRET=change-me-to-match-api-jwt-access-secret # Must match LawyerAI-api JWT_ACCESS_SECRET for /admin cookie verification.
JWT_SECRET=change-me-to-match-api-jwt-secret-if-used # Optional; use instead of JWT_ACCESS_SECRET when the API signs access tokens with JWT_SECRET only.
